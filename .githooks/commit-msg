#!/bin/sh
# 提交信息校验：防止 AI 或人工误提交英文、缺 scope 的 commit message。
# 启用方式：git config core.hooksPath .githooks

if command -v python >/dev/null 2>&1; then
    PYTHON_BIN="python"
elif command -v py >/dev/null 2>&1; then
    PYTHON_BIN="py -3"
else
    echo "提交信息校验失败：未找到 python 或 py，无法执行 commit-msg hook。"
    exit 1
fi

$PYTHON_BIN - "$1" <<'PY'
import re
import sys
from pathlib import Path


def read_subject(message_file: Path) -> str:
    """读取提交信息第一行，跳过空行和 Git 自动生成的注释行。"""
    lines = message_file.read_text(encoding="utf-8", errors="replace").splitlines()
    for line in lines:
        stripped = line.strip()
        if stripped and not stripped.startswith("#"):
            return stripped
    return ""


def main() -> int:
    """校验 commit message，失败时输出中文原因。"""
    message_file = Path(sys.argv[1])
    subject = read_subject(message_file)

    if not subject:
        print("提交信息不能为空。")
        return 1

    allowed_types = "feat|fix|docs|style|refactor|test|chore|perf"
    pattern = rf"^({allowed_types})\([a-z0-9._-]+\): .+"

    if not re.match(pattern, subject):
        print("提交信息格式不正确。")
        print("必须使用：<type>(<scope>): <中文描述>")
        print("示例：docs(git-rules): 强化提交规范执行")
        print("当前提交信息：{}".format(subject))
        return 1

    if not re.search(r"[\u4e00-\u9fff]", subject):
        print("提交信息必须包含中文描述，不能使用纯英文 subject。")
        print("示例：refactor(agents): 标准化 Agents 项目结构")
        print("当前提交信息：{}".format(subject))
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
PY
