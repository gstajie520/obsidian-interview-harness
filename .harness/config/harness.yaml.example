# Agent Harness 主配置模板
version: "1.0.0"
system_name: "通用面试陪练系统"

# LLM 配置（DeepSeek，兼容 OpenAI SDK + function calling）
llm:
  provider: "deepseek"
  base_url: "https://api.deepseek.com"
  base_url_env: "DEEPSEEK_BASE_URL"
  api_key: null
  api_key_env: "DEEPSEEK_API_KEY"
  model: "deepseek-chat"
  model_env: "DEEPSEEK_MODEL"
  temperature: 0.7
  max_tokens: 2000

# 上下文配置
# model/summary_model 为空时，默认跟随 llm.model。
context:
  max_tokens: 128000
  threshold: 0.92
  retain_recent_rounds: 10
  model: null
  summary_model: null

# 知识库配置
knowledge_base:
  default: "java_interview"           # 默认使用的知识库
  config_file: "knowledge_bases.yaml" # 知识库配置文件路径
  root_path: "知识库"                  # 知识库根目录

# 数据库配置
database:
  type: "sqlite"  # 默认使用 SQLite（零配置），改为 "mysql" 可切换到 MySQL
  # MySQL 配置（type 改为 mysql 时生效）
  host: "localhost"
  port: 3306
  database: "ai_interview"
  user: "root"
  password: "your-mysql-password"
  charset: "utf8mb4"
  pool_size: 10
  pool_recycle: 3600

# 记忆系统配置
memory:
  short_term:
    enabled: true
    max_turns: 20
  medium_term:
    enabled: true
    storage: "database"
  long_term:
    enabled: true
    files:
      - ".harness/memory/USER.md"
      - ".harness/memory/LEARNING_PATTERN.md"

# Agent 配置
agents:
  interviewer:
    enabled: true
    prompt_template: "agents/definitions/interviewer.md"
  supervisor:
    enabled: true
    prompt_template: "agents/definitions/supervisor.md"
  scheduler:
    enabled: true
    prompt_template: "agents/definitions/scheduler.md"
    algorithm: "sm2"
  linker:
    enabled: true
    prompt_template: "agents/definitions/linker.md"
    similarity_threshold: 0.7
  analyzer:
    enabled: true
    prompt_template: "agents/definitions/analyzer.md"
  buddy:
    enabled: true
    prompt_template: "agents/definitions/buddy.md"

# 复习调度配置
scheduler:
  algorithm: "sm2"
  initial_interval: 1
  second_interval: 6
  easiness_default: 2.5
  min_easiness: 1.3
  max_easiness: 3.0

# Web UI 配置
web_ui:
  host: "127.0.0.1"
  port: 8000
  debug: true
  cors_origins:
    - "http://localhost:8000"
    - "http://127.0.0.1:8000"

# 日志配置
logging:
  level: "INFO"
  file: ".harness/logs/harness.log"
